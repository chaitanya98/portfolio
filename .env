VITE_PORTFOLIO_EXPERIENCES_DATA={"experiences":[{"role":"Data Engineer","company":"Analyticore LLC","companyLink":"","period":"Jul 2025 — Present","description":"Designed and built 15+ production PySpark pipelines processing 500K+ records/day for wildfire (PSPS) analytics using Palantir Foundry Pipeline Builder. Built real-time geospatial dashboards in Workshop and Contour using GeoJSON, Geospatial SQL, and Spatial Joins. Configured AWS S3 Data Connections for secure ingestion into scalable PySpark pipelines.","technologies":["Palantir Foundry","PySpark","Pipeline Builder","Workshop","Contour","GeoJSON","Geospatial SQL","AWS S3"]},{"role":"Senior Technical Engineer","company":"Avaya","companyLink":"https://www.avaya.com/","period":"Jun 2023 — Feb 2025","description":"Designed and deployed a fully automated Agentic RAG Support Platform using AIP Chatbot Studio (Anthropic Claude Sonnet) with Native Tool Calling, PySpark ETL, and Ontology modeling (OSV2). Reduced MTTR from ~2 hours to ~30 minutes (75% improvement) and increased CSAT from 60% to 85%. Modeled a Digital Twin Ontology of Avaya Support Article objects, enabling sub-second transactional indexing via Foundry Action Types.","technologies":["Palantir Foundry","AIP Chatbot Studio","OSV2","PySpark","Anthropic Claude","RAG","Ontology"]},{"role":"Associate Technical Engineer","company":"Innovatia (supporting Avaya)","companyLink":"https://www.innovatia.net/","period":"Aug 2022 — May 2023","description":"Resolved complex technical escalations via root cause analysis on Avaya IP Office and AES environments. Executed LAN/WAN infrastructure support including IP addressing, routing, and switching optimizations.","technologies":["Avaya IP Office","AES","LAN/WAN","IP Addressing","Routing & Switching"]}]}
VITE_PORTFOLIO_PROJECTS_DATA={"projects":[{"title":"Wildfire Analytics & Disaster Management Platform","description":"Ingested NASA wildfire event data and province-boundary GeoJSON files; built geospatial joins and analytics surfacing province-level risk insights for disaster response and operational monitoring.","technologies":["Palantir Foundry","PySpark","GeoJSON","Geospatial SQL","Workshop","Contour"],"link":"https://chaitanya98.netlify.app","image":"wildfire-analytics.png"},{"title":"Agentic RAG Support Platform","description":"End-to-end platform combining PySpark ETL, Ontology modeling (OSV2), AIP Agentic RAG with Native Tool Calling, and event-driven automations — delivered 75% MTTR reduction and CSAT improvement from 60% to 85%.","technologies":["Palantir Foundry","AIP Chatbot Studio","OSV2","PySpark","Anthropic Claude Sonnet"],"link":"https://chaitanya98.netlify.app","image":"agentic-rag-support.png"},{"title":"Local RAG Chatbot – IP Office Knowledge Assistant","description":"Built a standalone Agentic RAG system integrating HuggingFace all-MiniLM-L6-v2 embeddings with ChromaDB and Groq LLaMA 3; deployed on Palantir Foundry with RBAC and Egress Policies configured.","technologies":["LangChain","LangGraph","ChromaDB","HuggingFace","Groq API","Streamlit"],"link":"https://chaitanya98.netlify.app","image":"ip-office-rag-chatbot.png"}]}
